# BOT Chain RPC endpoints
NEXT_PUBLIC_BOT_RPC_URL={{rpcUrl}}
NEXT_PUBLIC_BOT_MAINNET_RPC_URL=https://rpc.botchain.ai
NEXT_PUBLIC_BOT_TESTNET_RPC_URL=https://rpc.bohr.life

# BOT Chain chain ID to target by default (968 = Testnet, 677 = Mainnet)
NEXT_PUBLIC_BOT_CHAIN_ID={{chainId}}

# WalletConnect project ID — required for WalletConnect v2 support in RainbowKit
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
