# BOT Chain RPC endpoints
BOT_MAINNET_RPC=https://rpc.botchain.ai
BOT_TESTNET_RPC=https://rpc.bohr.life

# Default network selected during scaffolding
BOT_CHAIN_ID={{chainId}}
BOT_RPC_URL={{rpcUrl}}

# Private key for deployment (keep secret; never commit the real value)
PRIVATE_KEY=0x...

# Explorer API keys for contract verification (optional)
BOT_MAINNET_EXPLORER_API_KEY=
BOT_TESTNET_EXPLORER_API_KEY=
